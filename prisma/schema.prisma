generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  price       String
  features    String[]
  popular     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  eventDate String?
  eventType String?  // Service type chosen (e.g. Wedding Photography)
  location  String?  // Venue location details
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Testimonial {
  id         String   @id @default(cuid())
  clientName String
  rating     Int
  review     String
  imageUrl   String?
  type       String   @default("standard")
  extraData  String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model SiteAsset {
  id        String   @id @default(cuid())
  key       String   @unique
  imageUrl  String
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeddingProject {
  id          String    @id @default(cuid())
  clientName  String
  phone       String?
  email       String?
  religion    String    @default("Hindu") // "Hindu" | "Muslim" | "Destination" | "Other"
  status      String    @default("confirmed") // "confirmed" | "pending" | "completed" | "cancelled"
  totalAmount String?
  advancePaid String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
}

model Booking {
  id          String          @id @default(cuid())
  projectId   String?
  project     WeddingProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Standalone bookings use these directly; null for project-based bookings
  clientName  String?
  phone       String?
  email       String?
  totalAmount String?
  advancePaid String?
  
  eventType   String          // Specific function name or Standalone type
  eventDate   DateTime
  venue       String?
  notes       String?
  status      String          @default("confirmed")
  isBlocked   Boolean         @default(false)
  blockReason String?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

